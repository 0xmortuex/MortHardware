// Compile-only host contract for MortHardware.
// This supplies MortOS-owned state needed by one lifecycle helper. Freestanding
// Mort already provides the typed x86 inb/inw/inl/outb/outw/outl primitives.

let g_net_up: bool = false;
let g_gfx: bool = false;
let g_fb: u32 = 0;
let g_fb_pitch: u32 = 0;
let g_fb_w: u32 = 1024;
let g_fb_h: u32 = 768;
